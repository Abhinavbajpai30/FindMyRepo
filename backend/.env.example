# MongoDB Atlas connection string
# Format: mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<AppName>
MONGO_URI="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0"

# GitHub Personal Access Token (classic or fine-grained)
# Required for fetching repo data during ingestion
# Generate at: https://github.com/settings/tokens
GITHUB_TOKEN="github_pat_..."

# Google Gemini API Key
# Required for AI-powered search query generation and recommendations
# Generate at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY="AIza..."
