# Backend API base URL
VITE_API_BASE_URL=http://localhost:8000

# Endpoint URLs used directly in the app
VITE_SEARCH_API_URL=http://localhost:8000/search
VITE_USER_PREFERENCES_API=http://localhost:8000/userpreferences

# Relative endpoints appended to VITE_API_BASE_URL
VITE_ALL_REPOS_ENDPOINT=/allrepos
VITE_HIDDEN_GEMS_ENDPOINT=/hiddengem

# Instructions:
# 1. Copy this file to .env
# 2. Update the URLs to match your backend configuration
# 3. Make sure your backend is running on the specified URL
